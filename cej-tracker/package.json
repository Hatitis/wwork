{
  "name": "cej-tracker",
  "version": "1.0.0",
  "description": "Track changes on a CEJ rental search page",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "track": "node src/index.js",
    "web": "node src/webServer.js",
    "build-site": "node src/buildStaticSite.js",
    "test-discord": "node src/sendTestDiscord.js",
    "up": "bash ./scripts/start-all.sh",
    "down": "bash ./scripts/stop-all.sh",
    "test": "node --test"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "zod": "^3.24.2"
  }
}
